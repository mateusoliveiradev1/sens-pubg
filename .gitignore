# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-dev/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# test reports
/playwright-report/
/test-results/
/blob-report/
next-env.d.ts

# captured benchmark media lives locally; keep manifests/previews versionable
tests/fixtures/captured-clips/*.mp4
tests/fixtures/captured-clips/*.mov
tests/fixtures/captured-clips/*.mkv
tests/fixtures/captured-clips/*.webm

.vercel
