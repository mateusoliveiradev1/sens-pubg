{
  "name": "sens-pubg",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "benchmark": "tsx scripts/run-benchmark.ts tests/goldens/benchmark/synthetic-benchmark.v1.json tests/goldens/benchmark/synthetic-benchmark.baseline.json",
    "benchmark:captured": "tsx scripts/run-benchmark.ts tests/goldens/benchmark/captured-benchmark-draft.json",
    "benchmark:all": "npm run benchmark && npm run benchmark:captured",
    "benchmark:gate": "npm run benchmark:all && npm run validate:benchmark-coverage",
    "coach:smoke:groq": "tsx scripts/run-groq-coach-smoke.ts",
    "captured:autopilot-pack": "npm run generate:captured-review-decisions && npm run promote:captured-clips:with-review-decisions && npm run generate:benchmark-coverage && npm run generate:captured-benchmark-plan && npm run generate:captured-capture-slots",
    "generate:benchmark-coverage": "tsx scripts/generate-benchmark-coverage-report.ts tests/goldens/benchmark/captured-benchmark-draft.json docs/benchmark-coverage-2026-04-14.md \"Benchmark Coverage 2026-04-14\"",
    "validate:benchmark-coverage": "tsx scripts/validate-benchmark-coverage.ts tests/goldens/benchmark/captured-benchmark-draft.json",
    "validate:sdd-coverage": "tsx scripts/validate-benchmark-coverage.ts --sdd tests/goldens/benchmark/captured-benchmark-draft.json",
    "generate:captured-benchmark-plan": "tsx scripts/generate-captured-benchmark-plan.ts tests/goldens/benchmark/captured-benchmark-draft.json tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json docs/captured-benchmark-plan-2026-04-14.md \"Captured Benchmark Plan 2026-04-14\"",
    "generate:captured-capture-slots": "tsx scripts/generate-captured-capture-slots.ts tests/goldens/benchmark/captured-benchmark-draft.json tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json tests/fixtures/captured-clips/capture-slots.todo.v1.json 2026-04-14T23:30:00.000Z",
    "generate:captured-review-decisions": "tsx scripts/generate-captured-review-decisions.ts tests/goldens/benchmark/captured-benchmark-draft.json tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json tests/fixtures/captured-clips/review-decisions.todo.v1.json 2026-04-14T23:10:00.000Z",
    "validate:captured-labels": "tsx scripts/validate-captured-clip-labels.ts tests/fixtures/captured-clips/labels.todo.v1.json",
    "promote:captured-clips": "tsx scripts/promote-captured-clips.ts tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json captured-benchmark-draft",
    "promote:captured-clips:with-review-decisions": "tsx scripts/promote-captured-clips.ts tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json captured-benchmark-draft tests/fixtures/captured-clips/review-decisions.todo.v1.json",
    "generate:captured-frame-labels": "tsx scripts/generate-captured-frame-labels.ts tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels",
    "label:captured-frames": "tsx scripts/serve-captured-frame-labeler.ts tests/fixtures/captured-clips/labels",
    "generate:captured-labeling-kit": "tsx scripts/generate-captured-labeling-kit.ts tests/fixtures/captured-clips/intake.v1.json tests/fixtures/captured-clips/labels.todo.v1.json docs/captured-labeling-kit-2026-04-14.md",
    "smoke:local": "npx playwright test",
    "smoke:deployed": "tsx scripts/run-launch-smoke.ts",
    "verify:release": "npm run typecheck && npx vitest run && npm run benchmark:gate && npm run build && npm run smoke:local",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "idb": "^8.0.3",
    "next": "15.2.9",
    "next-auth": "^5.0.0-beta.30",
    "next-safe-action": "^8.0.12",
    "nuqs": "^2.8.8",
    "openai": "^6.34.0",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
